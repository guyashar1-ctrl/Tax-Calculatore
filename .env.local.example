# העתק ל-.env.local ומלא ערכים. הקובץ .env.local מוסתר מ-git ולעולם לא נדחף.

# ── Supabase (לקוח) ──
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ── שרת בלבד — לסקריפטים של סביבת הבדיקות ──
# בלי הקידומת VITE_ ⇒ לעולם לא נכנס ל-bundle של הדפדפן. נקרא רק ע"י scripts/.
# מקור: Supabase → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# ── התחברות אוטומטית כמשתמש בדיקה (DEV בלבד) ──
# הערכים הבאים נכתבים אוטומטית ע"י: npm run test:setup
VITE_DEV_AUTO_LOGIN=true
VITE_DEV_USER_EMAIL=e2e-test@firm.local
VITE_DEV_USER_PASSWORD=

# ── OCR (אופציונלי) ──
VITE_GEMINI_API_KEY=

# ── טוקן ניהול Supabase (אופציונלי, ל-MCP/CLI) ──
SUPABASE_ACCESS_TOKEN=
